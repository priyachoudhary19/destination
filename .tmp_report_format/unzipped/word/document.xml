fice/word/2020/wordml/sdtdatahash" xmlns:w16sdtfl="http://schemas.microsoft.com/office/word/2024/wordml/sdtformatlock" xmlns:w16se="http://schemas.microsoft.com/office/word/2015/wordml/symex" xmlns:wpg="http://schemas.microsoft.com/office/word/2010/wordprocessingGroup" xmlns:wpi="http://schemas.microsoft.com/office/word/2010/wordprocessingInk" xmlns:wne="http://schemas.microsoft.com/office/word/2006/wordml" xmlns:wps="http://schemas.microsoft.com/office/word/2010/wordprocessingShape" mc:Ignorable="w14 w15 w16se w16cid w16 w16cex w16sdtdh w16sdtfl w16du wp14"><w:body><w:p w14:paraId="4A916D93" w14:textId="72C26687" w:rsidR="001A449B" w:rsidRPr="001A449B" w:rsidRDefault="001A449B" w:rsidP="001A449B"><w:pPr><w:rPr><w:rFonts w:eastAsia="Times New Roman" /></w:rPr></w:pPr></w:p><w:p w14:paraId="482579F1" w14:textId="77777777" w:rsidR="001A449B" w:rsidRDefault="001A449B"><w:pPr><w:pStyle w:val="NormalWeb" /></w:pPr><w:r><w:t xml:space="preserve">This is to certify that Mr. </w:t></w:r><w:proofErr w:type="spellStart" /><w:r><w:t>Nandan</w:t></w:r><w:proofErr w:type="spellEnd" /><w:r><w:t xml:space="preserve"> Tiwari, a student of Master of Computer Applications (MCA), 4th Semester from Shri </w:t></w:r><w:proofErr w:type="spellStart" /><w:r><w:t>Govindram</w:t></w:r><w:proofErr w:type="spellEnd" /><w:r><w:t xml:space="preserve"> </w:t></w:r><w:proofErr w:type="spellStart" /><w:r><w:t>Seksaria</w:t></w:r><w:proofErr w:type="spellEnd" /><w:r><w:t xml:space="preserve"> Institute of Technology and Science (SGSITS), Indore, is currently undergoing a 6-month internship at </w:t></w:r><w:proofErr w:type="spellStart" /><w:r><w:t>BrainyBeam</w:t></w:r><w:proofErr w:type="spellEnd" /><w:r><w:t xml:space="preserve"> as an Android Intern, commencing from 12th January 2026.</w:t></w:r></w:p><w:p w14:paraId="60C3EEB6" w14:textId="77777777" w:rsidR="001A449B" w:rsidRDefault="001A449B"><w:pPr><w:pStyle w:val="NormalWeb" /></w:pPr><w:r><w:t xml:space="preserve">As part of his assigned responsibilities during the internship, he has been working on a project titled </w:t></w:r><w:r><w:rPr><w:rStyle w:val="Emphasis" /></w:rPr><w:t>“Smart Restaurant System”</w:t></w:r><w:r><w:t xml:space="preserve">, an Android-based application aimed at enhancing the traditional dining experience through automation and personalization. The system enables customers to scan a QR code placed at their table, which redirects them to an interactive chat interface within the application. An intelligent </w:t></w:r><w:proofErr w:type="spellStart" /><w:r><w:t>chatbot</w:t></w:r><w:proofErr w:type="spellEnd" /><w:r><w:t xml:space="preserve"> is integrated into the system to </w:t></w:r><w:proofErr w:type="spellStart" /><w:r><w:t>analyze</w:t></w:r><w:proofErr w:type="spellEnd" /><w:r><w:t xml:space="preserve"> user preferences such as mood, taste, and food choices, and accordingly provide personalized recommendations, thereby improving service efficiency and overall customer satisfaction.</w:t></w:r></w:p><w:p w14:paraId="57A9A5FD" w14:textId="7A7F46A4" w:rsidR="001A449B" w:rsidRDefault="00312A95"><w:pPr><w:pStyle w:val="NormalWeb" /></w:pPr><w:r><w:t xml:space="preserve">He </w:t></w:r><w:r w:rsidR="001A449B"><w:t xml:space="preserve">has demonstrated a strong understanding of the project requirements and has actively contributed to multiple phases of the development lifecycle. He has successfully completed requirement analysis, conducted a study of existing systems, and designed the user interface for the application. Furthermore, he has developed the foundational structure of the Android application, implemented QR code scanning functionality, and initiated the development of the </w:t></w:r><w:proofErr w:type="spellStart" /><w:r w:rsidR="001A449B"><w:t>chatbot</w:t></w:r><w:proofErr w:type="spellEnd" /><w:r w:rsidR="001A449B"><w:t xml:space="preserve"> interface. Currently, the project is in the development phase, with core features being systematically implemented and refined.</w:t></w:r></w:p><w:p w14:paraId="2251CE01" w14:textId="77777777" w:rsidR="001A449B" w:rsidRDefault="001A449B"><w:pPr><w:pStyle w:val="NormalWeb" /></w:pPr><w:r><w:t xml:space="preserve">Throughout the internship, he has exhibited dedication, a proactive learning attitude, and the ability to effectively address technical challenges such as </w:t></w:r><w:proofErr w:type="spellStart" /><w:r><w:t>chatbot</w:t></w:r><w:proofErr w:type="spellEnd" /><w:r><w:t xml:space="preserve"> design, QR code integration, and ensuring real-time responsiveness across various devices. His problem-solving skills and technical proficiency have shown consistent improvement.</w:t></w:r></w:p><w:p w14:paraId="3758AFD7" w14:textId="77777777" w:rsidR="001A449B" w:rsidRDefault="001A449B"><w:pPr><w:pStyle w:val="NormalWeb" /></w:pPr><w:r><w:t xml:space="preserve">In the forthcoming phase, he will focus on completing the </w:t></w:r><w:proofErr w:type="spellStart" /><w:r><w:t>chatbot</w:t></w:r><w:proofErr w:type="spellEnd" /><w:r><w:t xml:space="preserve"> logic, implementing a personalized recommendation engine, integrating backend and database functionalities, and performing comprehensive testing and debugging to ensure optimal system performance.</w:t></w:r></w:p><w:p w14:paraId="605E9CC7" w14:textId="77777777" w:rsidR="001A449B" w:rsidRDefault="001A449B"><w:pPr><w:pStyle w:val="NormalWeb" /></w:pPr><w:r><w:t>Overall, his performance during the internship period has been found to be satisfactory, and he is making steady progress towards the successful completion of the assigned project.</w:t></w:r></w:p><w:p w14:paraId="28B157AF" w14:textId="77777777" w:rsidR="001A449B" w:rsidRDefault="001A449B"><w:pPr><w:rPr><w:rFonts w:eastAsia="Times New Roman" /></w:rPr></w:pPr><w:r><w:rPr><w:rFonts w:eastAsia="Times New Roman" /><w:noProof /></w:rPr><mc:AlternateContent><mc:Choice Requires="wps"><w:drawing><wp:inline distT="0" distB="0" distL="0" distR="0" wp14:anchorId="3EBC0A44" wp14:editId="0E23C6